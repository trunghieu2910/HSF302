<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="com.mycompany.supperapp-PU" transaction-type="RESOURCE_LOCAL">
        <!-- Chỉ định JPA provider chuẩn của Hibernate -->
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <!-- Khai báo các entity class để map xuống table -->
        <class>com.mycompany.superapp.entity.Student</class>

        <!-- Cấu hình kết nối CSDL (Chuẩn Jakarta) -->
        <properties>
            <!-- JDBC Driver dùng MS SQL Server -->
            <property name="jakarta.persistence.jdbc.driver" value="com.microsoft.sqlserver.jdbc.SQLServerDriver"/>

            <!-- JDBC URL kết nối tới SQL Server -->
            <property name="jakarta.persistence.jdbc.url"
                      value="jdbc:sqlserver://localhost:1433;databaseName=HSF302;encrypt=true;trustServerCertificate=true"/>

            <!-- Tài khoản đăng nhập SQL Server -->
            <property name="jakarta.persistence.jdbc.user" value="sa"/>
            <property name="jakarta.persistence.jdbc.password" value="1234"/>

            <!-- ================= CẤU HÌNH ĐẶC THÙ CỦA HIBERNATE ================= -->

            <!-- Chỉ định Dialect để Hibernate tối ưu và generate code SQL chuẩn cho SQL Server -->
            <property name="hibernate.dialect" value="org.hibernate.dialect.SQLServerDialect"/>

            <!-- Tùy chọn thao tác với CSDL (DDL) -->
            <!-- "update": Tạo bảng nếu chưa có, tự thêm cột nếu Entity thay đổi. KHÔNG xóa bảng cũ hay dữ liệu. -->
            <!-- Các tùy chọn khác: "create" (xóa sạch tạo mới), "create-drop" (xóa khi đóng app), "none" (không làm gì) -->
            <!-- Tùy chọn thao tác với CSDL:
"none": Không làm gì cả - không kiểm tra, không tạo, không cập nhật gì cả
"validate": Kiểm tra bảng có sẵn có khớp với entity không - nếu lệch thì báo lỗi
"update": Cập nhật schema: tạo thêm bảng/cột nếu thiếu, không xoá gì cả
"create": Xoá toàn bộ bảng cũ rồi tạo bảng mới từ đầu
"create-drop": Tạo bảng khi chạy app, xoá toàn bộ bảng khi app dừng
"drop": (Hiếm dùng) Xoá toàn bộ bảng khi app khởi động - không tạo lại bảng -->
            <property name="hibernate.hbm2ddl.auto" value="update"/>

            <!-- Cho phép log SQL ra console để dễ debug -->
            <property name="hibernate.show_sql" value="true"/>

            <!-- Format code SQL in ra console cho dễ đọc thay vì nằm trên 1 dòng -->
            <property name="hibernate.format_sql" value="true"/>

            <!-- (Tùy chọn) Highlight màu cho SQL log -->
            <property name="hibernate.highlight_sql" value="true"/>

        </properties>
    </persistence-unit>
    <!-- KHAI BÁO THÔNG SỐ KẾT NỐI VỚI HỆ QUẢN TRỊ CƠ SỞ DỮ LIỆU.
         Bạn có thể khai báo nhiều <persistence-unit> nếu có nhiều database
         hoặc nhiều môi trường (dev, prod, test). -->
</persistence>